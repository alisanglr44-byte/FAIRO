# Copy this to .env and fill in your values
# NEVER commit .env to GitHub

# From BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# From rapidapi.com — one key covers Sky Scrapper + Booking.com
RAPIDAPI_KEY=

# From travelpayouts.com (apply free, instant approval)
TRAVELPAYOUTS_MARKER=

# From booking.com/affiliate-program
BOOKING_AFFILIATE_ID=

# From supabase.com — Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
